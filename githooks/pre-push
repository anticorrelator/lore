#!/usr/bin/env bash
# pre-push — mechanical arm of the retro seam-drift chain (skills/CONVENTIONS.md,
# "Protocol Mutation Chains"). Versioned in githooks/; activate once per clone:
#   git config core.hooksPath githooks
#
# For every pushed ref: run check-retro-seam-drift.sh over the outgoing range.
# When the range touches a protected reader, the retro SKILL, or the contract
# suite itself, also run the full reader contract tests (lore test seams does
# the same set by hand). Fast path: ranges that touch none of it pay only the
# checker's diff walk.

set -uo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

CHECKER="scripts/check-retro-seam-drift.sh"
[[ -f "$CHECKER" ]] || exit 0   # pre-checker clone; nothing to enforce

PROTECTED_PATTERN='^(scripts/retro-.*\.sh|scripts/settlement-queue\.sh|scripts/settlement-processor\.py|scripts/scorecard-read\.sh|scripts/session-events\.sh|scripts/consumption-contradiction-read\.sh|skills/retro/SKILL\.md|tests/frameworks/retro_prepare\.bats|scripts/check-retro-seam-drift\.sh|tests/test_retro_seam_drift_check\.sh|tests/test_retro_evidence_pack_protocol\.sh)$'

ZERO="0000000000000000000000000000000000000000"
overall_rc=0
run_suite=0

while read -r local_ref local_sha remote_ref remote_sha; do
  [[ "$local_sha" == "$ZERO" ]] && continue   # deleting a remote ref
  if [[ "$remote_sha" == "$ZERO" ]]; then
    # New remote branch: bound the walk at origin/main when we have it.
    if git rev-parse --verify origin/main >/dev/null 2>&1; then
      base="$(git merge-base origin/main "$local_sha" 2>/dev/null || echo "")"
    else
      base=""
    fi
  else
    base="$remote_sha"
  fi
  [[ -z "$base" || "$base" == "$local_sha" ]] && continue

  if ! bash "$CHECKER" "$base" "$local_sha"; then
    overall_rc=1
  fi
  if git diff --name-only "$base" "$local_sha" | grep -Eq "$PROTECTED_PATTERN"; then
    run_suite=1
  fi
done

if [[ $run_suite -eq 1 ]]; then
  echo "[pre-push] range touches protected retro seam files — running contract suite"
  if command -v bats &>/dev/null; then
    bats tests/frameworks/retro_prepare.bats || overall_rc=1
  else
    echo "[pre-push] bats not found — contract suite NOT run; failing closed" >&2
    overall_rc=1
  fi
  bash tests/test_retro_seam_drift_check.sh || overall_rc=1
fi

if [[ $overall_rc -ne 0 ]]; then
  echo "[pre-push] retro seam checks failed — push blocked. Run 'lore test seams' to reproduce." >&2
fi
exit $overall_rc
