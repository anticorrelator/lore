retro_usage() {
  # Role-aware help: maintainer verbs are omitted from the contributor view
  # (task-54) so the contributor surface stays minimal and discovery-safe.
  # Maintainers see the full surface.
  local role
  role=$(resolve_role)
  cat >&2 <<EOF
lore retro — federated retro pooling (Phase 9 of the settlement architecture)

Usage: lore retro <subcommand> [args...]

Subcommands:
  export      Export a redacted retro bundle for submission to a maintainer
EOF
  if [[ "$role" == "maintainer" ]]; then
    cat >&2 <<EOF
  import      Ingest a contributor bundle into the maintainer's private pool [maintainer]
  aggregate   Compute convergence tags over the imported pool              [maintainer]
EOF
  fi
  cat >&2 <<EOF

Options:
  --help, -h    Show this help

Notes:
  'export' is contributor-facing and requires no role. 'import' and
  'aggregate' require role=maintainer in ~/.lore/config/settings.json
  (or per-repo ~/.lore/repos/<repo>/config.json). Current role: $role.
  See _research/multi-user-evolution-design.md for the full federation design.
EOF
}

