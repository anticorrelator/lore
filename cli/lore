# --- Query (seeds-keyed compositional retrieval) ---
cmd_query() {
  local seeds=""
  local hop_budget=0
  local budget=""
  local scale_set=""
  local type_filter="knowledge"
  local exclude_category=""
  local format="json"
  local positional_args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)
        cat >&2 <<'EOF'
Usage: lore query [<seed>] [--seeds <csv>] [--hop-budget N] [--budget N]
                  [--scale-set <csv>]
                  [--type knowledge|work|all]
                  [--exclude-category <cat>] [--format json|prompt]

Seeds-keyed compositional retrieval. Seeds may be backlink references
(knowledge:<path> or work:<slug>, with or without [[...]]) or query text.
A single positional argument is treated as --seeds <arg>.

Flags:
  --seeds <csv>          Comma-separated seed list (backlinks or query text)
  --hop-budget N         0=no expand (default), >=1=TF-IDF concordance widening
  --budget N             Budget-aware search (mutually exclusive with --hop-budget >=1)
  --scale-set <csv>      Required scale filter; entries pass when their label set
                         intersects the requested set (multi-label aware).
                         Entries without a declared scale are excluded.
  --type <t>             Source type: knowledge, work, or all (default: knowledge)
  --exclude-category <c> Exclude entries in this category
  --format json|prompt   Output format (default: json)
EOF
        return 0
        ;;
      --seeds)
        seeds="$2"
        shift 2
        ;;
      --hop-budget)
        hop_budget="$2"
        shift 2
        ;;
      --budget)
        budget="$2"
        shift 2
        ;;
      --scale-set)
        scale_set="$2"
        shift 2
        ;;
      --min-scale|--min-scale=*|--max-scale|--max-scale=*)
        echo "Error: --min-scale and --max-scale were retired in the multi-label scale migration." >&2
        echo "  Use --scale-set <csv> instead — entries pass when their label set intersects the requested set." >&2
        echo "  Example: lore query --seeds <seed> --scale-set subsystem,implementation" >&2
        return 2
        ;;
      --type)
        type_filter="$2"
        shift 2
        ;;
      --exclude-category)
        exclude_category="$2"
        shift 2
        ;;
      --format)
        format="$2"
        shift 2
        ;;
      -*)
        echo "Error: unknown flag '$1'" >&2
        return 1
        ;;
      *)
        positional_args+=("$1")
        shift
        ;;
    esac
  done

  # A single positional arg is shorthand for --seeds
  if [[ ${#positional_args[@]} -gt 0 && -z "$seeds" ]]; then
    seeds="${positional_args[0]}"
  elif [[ ${#positional_args[@]} -gt 0 ]]; then
    echo "Error: unexpected positional argument '${positional_args[0]}' when --seeds already set" >&2
    return 1
  fi

  # Empty seed list is a caller error
  if [[ -z "$seeds" ]]; then
    echo "Usage: lore query [<seed>] [--seeds <csv>] [--hop-budget N] [--budget N] [--format json|prompt]" >&2
    echo "Error: seed list is empty — provide at least one seed via positional arg or --seeds" >&2
    return 1
  fi

  # --scale-set is required for programmatic retrieval
  if [[ -z "$scale_set" ]]; then
    echo "Error: --scale-set is required. Declare your retrieval scale to proceed." >&2
    echo "  Use: lore query --seeds <seed> --scale-set <bucket>" >&2
    echo "  Buckets: abstract, architecture, subsystem, implementation" >&2
    return 1
  fi

  # Mutual exclusion: --budget and --hop-budget >=1 cannot be combined
  if [[ -n "$budget" && "$hop_budget" -ge 1 ]]; then
    echo "Error: --budget and --hop-budget >=1 are mutually exclusive. Use --hop-budget 0 for budget-only search." >&2
    return 1
  fi

  # Warn when hop-budget > 1 (capped to one-hop)
  if [[ "$hop_budget" -gt 1 ]]; then
    echo "Notice: --hop-budget $hop_budget capped to one-hop expansion (multi-hop not yet implemented)" >&2
  fi

  local kdir
  kdir="$(resolve_kdir)"

  # --- Partition seeds into backlinks vs query-text ---
  local backlink_seeds=()
  local query_parts=()

  IFS=',' read -ra SEED_ARR <<< "$seeds"
  for raw_seed in "${SEED_ARR[@]}"; do
    # Trim whitespace
    local seed="${raw_seed#"${raw_seed%%[![:space:]]*}"}"
    seed="${seed%"${seed##*[![:space:]]}"}"
    # Strip surrounding [[ ]] if present
    local inner="${seed#[[}"
    inner="${inner%]]}"
    if [[ "$inner" == knowledge:* || "$inner" == work:* ]]; then
      backlink_seeds+=("$inner")
    else
      query_parts+=("$seed")
    fi
  done

  # --- Resolve backlink seeds ---
  local resolved_paths=()
  if [[ ${#backlink_seeds[@]} -gt 0 ]]; then
    # Wrap bare seeds (without [[ ]]) to full [[type:target]] form expected by pk_resolve.py
    local wrapped_seeds=()
    for bs in "${backlink_seeds[@]}"; do
      wrapped_seeds+=("[[$bs]]")
    done
    local resolve_json
    resolve_json=$(python3 "$SCRIPTS_DIR/pk_cli.py" resolve "$kdir" "${wrapped_seeds[@]}" --json 2>/dev/null || true)
    if [[ -n "$resolve_json" ]]; then
      # Extract file_path from resolved entries; log unresolved to stderr
      while IFS= read -r line; do
        resolved_paths+=("$line")
      done < <(python3 - "$resolve_json" "$kdir" <<'RESOLVE_PY'
import json, sys, os
data = json.loads(sys.argv[1])
kdir = sys.argv[2]
for r in data:
    if r.get("resolved"):
        # Build relative path from kdir
        abs_path = r.get("file_path", "")
        if not abs_path:
            # Reconstruct from source_type + target
            st = r.get("source_type", "")
            tgt = r.get("target", "")
            if st == "knowledge":
                abs_path = os.path.join(kdir, tgt + ".md")
            elif st == "work":
                abs_path = os.path.join(kdir, "_work", tgt, "_meta.json")
        if abs_path:
            try:
                rel = os.path.relpath(abs_path, kdir)
                print(rel)
            except ValueError:
                pass
    else:
        print(f"Warning: unresolved backlink '{r.get('backlink', '')}': {r.get('error', 'not found')}", file=sys.stderr)
RESOLVE_PY
      )
    fi
    # If all backlinks resolved to empty and no query_parts, it's a success with empty result
  fi

  # --- Build query string ---
  local query=""
  if [[ ${#query_parts[@]} -gt 0 ]]; then
    query="${query_parts[*]}"
  elif [[ ${#backlink_seeds[@]} -gt 0 ]]; then
    # Use the first backlink target as a query fallback
    query="${backlink_seeds[0]#knowledge:}"
    query="${query#work:}"
    # Use last path component for search readability
    query="${query##*/}"
    # Strip heading fragment
    query="${query%%#*}"
  fi

  # If no usable query (all-backlinks resolved, no text), emit empty result
  if [[ -z "$query" ]]; then
    if [[ "$format" == "prompt" ]]; then
      : # empty output for prompt format
    else
      echo "[]"
    fi
    return 0
  fi

  # --- Build pk_cli.py search args ---
  # Scale filtering is delegated to Searcher (single authority — D4 consolidation).
  # category=preferences and scale=abstract entries bypass the scale filter inside
  # Searcher.search; no duplicate post-filter is applied here.
  local search_args=("search" "$kdir" "$query" "--json" "--caller" "lore-query" "--scale-set" "$scale_set")
  [[ "$type_filter" != "all" ]] && search_args+=("--type" "$type_filter")
  [[ -n "$exclude_category" ]] && search_args+=("--exclude-category" "$exclude_category")

  if [[ -n "$budget" ]]; then
    search_args+=("--budget" "$budget")
  elif [[ "$hop_budget" -ge 1 ]]; then
    search_args+=("--expand")
  fi

  # --- Execute search ---
  local raw_results
  raw_results=$(python3 "$SCRIPTS_DIR/pk_cli.py" "${search_args[@]}" 2>/dev/null || true)
  if [[ -z "$raw_results" ]]; then
    raw_results="[]"
  fi

  # --- Post-process: inject path field only; scale filter already applied by Searcher ---
  local processed
  processed=$(python3 - "$raw_results" "$kdir" <<'POST_PY'
import json, sys

raw = sys.argv[1]
data = json.loads(raw)

is_budget = isinstance(data, dict) and "full" in data

def inject_path(entries):
    out = []
    for r in entries:
        entry = dict(r)
        if "path" not in entry:
            entry["path"] = entry.get("file_path", "")
        for s in entry.get("similar_entries", []):
            if "path" not in s:
                s["path"] = s.get("file_path", "")
        out.append(entry)
    return out

if is_budget:
    data["full"] = inject_path(data["full"])
    data["titles_only"] = inject_path(data["titles_only"])
else:
    data = inject_path(data)

print(json.dumps(data, indent=2))
POST_PY
  )

  # --- Format output ---
  if [[ "$format" == "prompt" ]]; then
    # Emit ## Prior Knowledge markdown block from results
    python3 - "$processed" "$kdir" <<'PROMPT_PY'
import json, sys, os

data = json.loads(sys.argv[1])
kdir = sys.argv[2]

# Flatten budget or flat shape
if isinstance(data, dict) and "full" in data:
    entries = data["full"]
else:
    entries = data

if not entries:
    sys.exit(0)

lines = ["## Prior Knowledge"]
for r in entries:
    heading = r.get("heading", "")
    fp = r.get("file_path", r.get("path", ""))
    if fp.endswith(".md"):
        fp = fp[:-3]
    snippet = r.get("snippet", r.get("content", ""))
    if len(snippet) > 300:
        snippet = snippet[:300].rsplit(" ", 1)[0] + "..."
    # Build backlink
    backlink = f"[[knowledge:{fp}#{heading}]]" if heading else f"[[knowledge:{fp}]]"
    lines.append(f"- {backlink}")
    if snippet:
        lines.append(f"  {snippet.splitlines()[0][:200]}")
    for s in r.get("similar_entries", []):
        sfp = s.get("file_path", s.get("path", ""))
        if sfp.endswith(".md"):
            sfp = sfp[:-3]
        sh = s.get("heading", "")
        sbl = f"[[knowledge:{sfp}#{sh}]]" if sh else f"[[knowledge:{sfp}]]"
        lines.append(f"  - See also: {sbl}")

print("\n".join(lines))
PROMPT_PY
  else
    echo "$processed"
  fi
}

# --- Search ---
cmd_search() {
  local type="all"
  local json_flag=""
  local scale_set=""
  local caller="cli"
  local args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)
        echo "Usage: lore search <query> [--scale-set <bucket>] [--caller <id>] [--type knowledge|work|all] [--json]" >&2
        return 0
        ;;
      --type)
        type="$2"
        shift 2
        ;;
      --json)
        json_flag="--json"
        shift
        ;;
      --scale-set)
        scale_set="$2"
        shift 2
        ;;
      --scale-set=*)
        scale_set="${1#--scale-set=}"
        shift
        ;;
      --caller)
        caller="$2"
        shift 2
        ;;
      --caller=*)
        caller="${1#--caller=}"
        shift
        ;;
      *)
        args+=("$1")
        shift
        ;;
    esac
  done

  if [[ ${#args[@]} -eq 0 ]]; then
    echo "Usage: lore search <query> [--scale-set <bucket>] [--caller <id>] [--type knowledge|work|all] [--json]" >&2
    return 1
  fi

  if [[ -z "$scale_set" ]]; then
    if [[ -n "$json_flag" ]]; then
      echo '{"error":"--scale-set is required for lore search; declare your retrieval scale, e.g. --scale-set implementation"}' >&2
      return 1
    fi
    echo "Scale declaration required: add --scale-set <bucket> to your search." >&2
    echo "  Example: lore search \"${args[0]:-<query>}\" --scale-set implementation" >&2
    echo "  Buckets: abstract, architecture, subsystem, implementation" >&2
    return 1
  fi

  local query="${args[0]}"
  local kdir
  kdir="$(resolve_kdir)"

  if [[ -n "$json_flag" ]]; then
    case "$type" in
      knowledge)
        python3 "$SCRIPTS_DIR/pk_cli.py" search "$kdir" "$query" --scale-set "$scale_set" --caller "$caller" --json "${args[@]:1}"
        ;;
      work)
        python3 "$SCRIPTS_DIR/pk_cli.py" search "$kdir" "$query" --scale-set "$scale_set" --caller "$caller" --json --type work "${args[@]:1}"
        ;;
      all)
        local k_json w_json
        k_json="$(python3 "$SCRIPTS_DIR/pk_cli.py" search "$kdir" "$query" --scale-set "$scale_set" --caller "$caller" --json "${args[@]:1}")"
        w_json="$(python3 "$SCRIPTS_DIR/pk_cli.py" search "$kdir" "$query" --scale-set "$scale_set" --caller "$caller" --json --type work "${args[@]:1}")"
        python3 -c "import json,sys; a=json.loads(sys.argv[1]); b=json.loads(sys.argv[2]); print(json.dumps(a+b,indent=2))" "$k_json" "$w_json"
        ;;
      *)
        echo "Error: --type must be knowledge, work, or all" >&2
        return 1
        ;;
    esac
  else
    case "$type" in
      knowledge)
        python3 "$SCRIPTS_DIR/pk_cli.py" search "$kdir" "$query" --scale-set "$scale_set" --caller "$caller" "${args[@]:1}"
        ;;
      work)
        "$SCRIPTS_DIR/search-work.sh" "$query"
        ;;
      all)
        python3 "$SCRIPTS_DIR/pk_cli.py" search "$kdir" "$query" --scale-set "$scale_set" --caller "$caller" "${args[@]:1}"
        echo ""
        "$SCRIPTS_DIR/search-work.sh" "$query"
        ;;
      *)
        echo "Error: --type must be knowledge, work, or all" >&2
        return 1
        ;;
    esac
  fi
}

