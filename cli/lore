# --- Scale subgroup ---
cmd_scale() {
  if [[ $# -eq 0 ]]; then
    scale_usage
    return 1
  fi

  local subcmd="$1"
  shift

  case "$subcmd" in
    --help|-h)
      scale_usage
      return 0
      ;;
    compute)
      echo "Error: 'lore scale compute' has been removed. Scale is now declared by the author using the 4-bucket rubric (abstract, architecture, subsystem, implementation). See the scale rubric in your agent template or SKILL.md for guidance." >&2
      return 1
      ;;
    registry)
      "$SCRIPTS_DIR/scale-registry.sh" "$@"
      ;;
    *)
      echo "Error: unknown scale subcommand '$subcmd'" >&2
      echo "" >&2
      scale_usage
      return 1
