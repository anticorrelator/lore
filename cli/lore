}

# --- Scorecard subgroup ---
cmd_scorecard() {
  if [[ $# -eq 0 ]]; then
    scorecard_usage
    return 1
  fi

  local subcmd="$1"
  shift

  case "$subcmd" in
    --help|-h)
      scorecard_usage
      return 0
      ;;
    append)
      "$SCRIPTS_DIR/scorecard-append.sh" "$@"
      ;;
    rollup)
      "$SCRIPTS_DIR/scorecard-rollup.sh" "$@"
      ;;
    current)
      local kdir current_file
      kdir="$(resolve_kdir)"
      current_file="$kdir/_scorecards/_current.json"
      if [[ ! -f "$current_file" ]]; then
        echo "Error: $current_file does not exist. Run 'lore scorecard rollup' first." >&2
        return 1
      fi
      cat "$current_file"
      ;;
    rows)
      local kdir rows_file
      kdir="$(resolve_kdir)"
      rows_file="$kdir/_scorecards/rows.jsonl"
      if [[ ! -f "$rows_file" ]]; then
        echo "Error: $rows_file does not exist. Run 'lore scorecard append' to create it." >&2
        return 1
      fi
      cat "$rows_file"
      ;;
    *)
      echo "Error: unknown scorecard subcommand '$subcmd'" >&2
      echo "" >&2
      scorecard_usage
      return 1
      ;;
  esac
}

