cmd_followup() {
  if [[ $# -eq 0 ]]; then
    followup_usage
    return 1
  fi

  local subcmd="$1"
  shift

  case "$subcmd" in
    --help|-h)
      followup_usage
      return 0
      ;;
    create)
      "$SCRIPTS_DIR/create-followup.sh" "$@"
      ;;
    list)
      "$SCRIPTS_DIR/list-followups.sh" "$@"
      ;;
    view)
      "$SCRIPTS_DIR/load-followup.sh" "$@"
      ;;
    update)
      "$SCRIPTS_DIR/update-followup.sh" "$@"
      ;;
    promote)
      "$SCRIPTS_DIR/promote-followup.sh" "$@"
      ;;
    dismiss)
      "$SCRIPTS_DIR/dismiss-followup.sh" "$@"
      ;;
    archive)
      "$SCRIPTS_DIR/archive-followup.sh" "$@"
      ;;
    unarchive)
      "$SCRIPTS_DIR/unarchive-followup.sh" "$@"
      ;;
    delete)
      "$SCRIPTS_DIR/delete-followup.sh" "$@"
      ;;
    post-review)
      "$SCRIPTS_DIR/post-proposed-review.sh" "$@"
      ;;
    summarize)
      "$SCRIPTS_DIR/generate-review-summary.sh" "$@"
      ;;
    reconcile)
      "$SCRIPTS_DIR/reconcile-reviews.sh" "$@"
      ;;
    *)
      echo "Error: unknown followup subcommand '$subcmd'" >&2
      echo "" >&2
      followup_usage
      return 1
      ;;
  esac
}

# --- Top-level dispatch ---
if [[ $# -eq 0 ]]; then
  exec lore-tui
fi

case "$1" in
  --help|-h)
    usage
    exit 0
    ;;
  --version|-v)
    echo "lore $LORE_VERSION"
    exit 0
    ;;
  read)
    shift
    "$SCRIPTS_DIR/filtered-read.sh" "$@"
    ;;
  search)
    shift
    cmd_search "$@"
    ;;
  capture)
    shift
    "$SCRIPTS_DIR/capture.sh" "$@"
    ;;
  annotate)
    shift
    "$SCRIPTS_DIR/annotate.sh" "$@"
    ;;
  audit)
    shift
    "$SCRIPTS_DIR/audit-artifact.sh" "$@"
    ;;
  resolve)
    shift
    if [[ $# -eq 0 ]]; then
      resolve_kdir
    else
      case "$1" in
        --help|-h)
          echo "Usage: lore resolve [backlink...]" >&2
          echo "  No args: print knowledge directory path" >&2
          echo "  With args: resolve [[backlink]] references" >&2
          exit 0
          ;;
        *)
          kdir="$(resolve_kdir)"
          python3 "$SCRIPTS_DIR/pk_cli.py" resolve "$kdir" "$@"
          ;;
      esac
    fi
    ;;
  prefetch)
    shift
    "$SCRIPTS_DIR/prefetch-knowledge.sh" "$@"
    ;;
  index)
    shift
    "$SCRIPTS_DIR/generate-index.sh" "$@"
    ;;
  init)
    shift
    "$SCRIPTS_DIR/init-repo.sh" "$@"
    ;;
  init-work)
    shift
    "$SCRIPTS_DIR/init-work.sh" "$@"
    ;;
  heal)
    shift
    "$SCRIPTS_DIR/heal-knowledge.sh" "$@"
    "$SCRIPTS_DIR/heal-work.sh" "$@"
    ;;
  stats)
    shift
    kdir="$(resolve_kdir)"
    python3 "$SCRIPTS_DIR/pk_cli.py" stats "$kdir" "$@"
    ;;
  check-links)
    shift
    kdir="$(resolve_kdir)"
    python3 "$SCRIPTS_DIR/pk_cli.py" check-links "$kdir" "$@"
    ;;
  curate)
    shift
    "$SCRIPTS_DIR/curate-scan.sh" "$@"
    ;;
  status)
    shift
    "$SCRIPTS_DIR/status.sh" "$@"
    ;;
  assemble)
    shift
    "$SCRIPTS_DIR/assemble-claude-md.sh" "$@"
    ;;
  analyze)
    shift
    cmd_analyze "$@"
    ;;
  followup)
    shift
    cmd_followup "$@"
    ;;
  work)
    shift
    cmd_work "$@"
    ;;
  journal)
    shift
    "$SCRIPTS_DIR/journal.sh" "$@"
    ;;
  thread)
    shift
    cmd_thread "$@"
    ;;
  migrate)
    shift
    cmd_migrate "$@"
    ;;
  manifest)
    shift
    cmd_manifest "$@"
    ;;
  bootstrap)
    shift
    cmd_bootstrap "$@"
    ;;
  backlinks)
    shift
    cmd_backlinks "$@"
    ;;
  ceremony)
    shift
    cmd_ceremony "$@"
    ;;
  agent)
    shift
    cmd_agent "$@"
    ;;
  scale)
    shift
    cmd_scale "$@"
    ;;
  scorecard)
    shift
    cmd_scorecard "$@"
    ;;
  retro)
    shift
    cmd_retro "$@"
    ;;
  knowledge-tree)
    shift
    "$SCRIPTS_DIR/knowledge-tree.sh" "$@"
    ;;
  batch-spec)
    shift
    "$SCRIPTS_DIR/batch-spec.sh" "$@"
    ;;
  batch-implement)
    shift
    "$SCRIPTS_DIR/batch-implement.sh" "$@"
    ;;
  batch-capture)
    shift
    "$SCRIPTS_DIR/batch-capture.sh" "$@"
    ;;
  doctor)
    shift
    "$SCRIPTS_DIR/doctor.sh" "$@"
    ;;
  rebuild)
    if ! command -v go >/dev/null 2>&1; then
      echo "Error: go not found on PATH" >&2
      exit 1
    fi
    REPO_DIR="$(dirname "$SCRIPTS_DIR")"
    TUI_DIR="$REPO_DIR/tui"
    if [[ ! -d "$TUI_DIR" ]]; then
      echo "Error: tui/ directory not found at $TUI_DIR" >&2
      exit 1
    fi
    echo "Building lore-tui..."
    (cd "$TUI_DIR" && go build -o "$HOME/.local/bin/lore-tui" .)
    echo "Installed: ~/.local/bin/lore-tui"
    ;;
  *)
    echo "Error: unknown command '$1'" >&2
    echo "" >&2
    usage
    exit 1
    ;;
esac
