#!/usr/bin/env bash
# lore — CLI dispatcher for the lore knowledge system
# Routes subcommands to scripts in ~/.lore/scripts/

set -euo pipefail

LORE_VERSION="0.1.0"

# Resolve SCRIPTS_DIR via the ~/.lore/scripts symlink
SCRIPTS_DIR="$(cd "$(readlink ~/.lore/scripts || echo ~/.lore/scripts)" && pwd)"
source "$SCRIPTS_DIR/lib.sh"

# Resolve KDIR once for commands that need it (suppress errors for commands that don't)
resolve_kdir() {
  "$SCRIPTS_DIR/resolve-repo.sh"
}

# --- Role gate (Phase 9) ---
# Maintainer-only verbs route through this guard. If the resolved role (see
# resolve_role in scripts/lib.sh) is not "maintainer", emit a clear error and
# exit 2. Exit 2 is distinct from usage-error (1) and script-error (3+) so
# callers and tests can distinguish "you lack permission" from "your argv is
# wrong". The error message names the escape hatches: per-repo config.json,
# user-level settings.json, and the LORE_ROLE env override for one-off use.
#
# Usage: require_maintainer <verb-for-error-message>
require_maintainer() {
  local verb="${1:-command}"
  local role
  role=$(resolve_role)
  if [[ "$role" != "maintainer" ]]; then
    cat >&2 <<EOF
Error: 'lore $verb' requires role=maintainer (current role: $role).

Maintainer verbs mutate shared templates and the evaluation pool. Contributors
submit evidence via 'lore retro export' (and any distribution channel the
project uses) and let the maintainer merge it. See
_research/multi-user-evolution-design.md for the full federation model.

To become a maintainer for this repo, add one of:
  • \$LORE_DATA_DIR/repos/<repo>/config.json  (preferred, per-repo opt-in)
      {"role": "maintainer"}
  • \$LORE_DATA_DIR/config/settings.json     (user-level default)
      {"role": "maintainer"}

One-off override (current invocation only):
  LORE_ROLE=maintainer lore $verb ...
EOF
    exit 2
  fi
}

